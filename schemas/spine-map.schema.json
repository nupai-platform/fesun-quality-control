{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schema_version", "spines"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "number", "const": 1.1 },
    "spines": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "criticality", "systems", "status", "segments"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "criticality": { "enum": ["standard", "critical"] },
          "systems": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "status": { "enum": ["skeleton", "frozen"] },
          "segments": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["name", "systems", "contracts", "tests"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "systems": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
                "contracts": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
                "tests": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
