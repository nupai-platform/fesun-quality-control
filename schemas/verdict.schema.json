{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fesun.quality/schemas/verdict.schema.json",
  "title": "FESUN Verdict v1.1.1",
  "type": "object",
  "required": [
    "schema_version", "computed_by", "generated_at", "verdict", "merge_allowed",
    "bug_id", "profile", "checks", "test_summary", "evidence_count",
    "packet_sha256", "qc_sha", "reasons", "partial_reasons", "blocked_reasons"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "number", "const": 1.1 },
    "computed_by": { "type": "string", "const": "verdict-gate.ts" },
    "generated_at": { "type": "string", "format": "date-time" },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "PARTIAL"] },
    "merge_allowed": { "type": "boolean" },
    "bug_id": { "type": "string" },
    "profile": {
      "type": "string",
      "enum": ["FAST", "STANDARD", "CRITICAL", "CROSS_SYSTEM", "MANUAL_REVIEW"]
    },
    "checks": {
      "type": "object",
      "required": [
        "packet_valid", "evidence_integrity", "execution_policy",
        "no_runtime_business_mutation", "no_weak_assertions", "all_tests_passed",
        "oracle_assertions_matched", "run_1_passed", "run_2_passed", "run_2_fresh_data",
        "counterfactual_ok", "no_orphan_integrations"
      ],
      "additionalProperties": false,
      "properties": {
        "packet_valid": { "type": "boolean" },
        "evidence_integrity": { "type": "boolean" },
        "execution_policy": { "type": "boolean" },
        "no_runtime_business_mutation": { "type": "boolean" },
        "no_weak_assertions": { "type": "boolean" },
        "all_tests_passed": { "type": "boolean" },
        "oracle_assertions_matched": { "type": "boolean" },
        "run_1_passed": { "type": "boolean" },
        "run_2_passed": { "type": "boolean" },
        "run_2_fresh_data": { "type": "boolean" },
        "counterfactual_ok": { "type": "boolean" },
        "no_orphan_integrations": { "type": "boolean" }
      }
    },
    "test_summary": {
      "type": "object",
      "required": ["total", "passed", "failures", "flaky", "ok"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failures": { "type": "array", "items": { "type": "string" } },
        "flaky": { "type": "boolean" },
        "ok": { "type": "boolean" }
      }
    },
    "evidence_count": { "type": "integer", "minimum": 0 },
    "packet_sha256": { "$ref": "#/definitions/sha256" },
    "qc_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "failure_classification": {
      "type": "string",
      "enum": [
        "PRODUCT_BUG", "TEST_WORKER_MODIFIED_BUSINESS_CODE", "WEAK_ASSERTION",
        "FLAKY", "INSUFFICIENT_EVIDENCE", "MISSING_FACT_SOURCE"
      ]
    },
    "reasons": { "type": "array", "items": { "type": "string" } },
    "partial_reasons": { "type": "array", "items": { "type": "string" } },
    "blocked_reasons": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "verdict": { "const": "PASS" } } },
      "then": { "properties": { "merge_allowed": { "const": true } } },
      "else": { "properties": { "merge_allowed": { "const": false } } }
    }
  ],
  "definitions": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
