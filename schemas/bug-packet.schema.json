{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fesun.quality/schemas/bug-packet.schema.json",
  "title": "FESUN Bug Packet v1.1.1",
  "description": "单一 Bug 事实源。所有风险等级都必须提供至少一条可机器复判的 Oracle assertion。",
  "type": "object",
  "required": [
    "schema_version",
    "bug",
    "expected_business_result",
    "environment",
    "risk_claim",
    "test_data"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "number", "const": 1.1 },
    "bug": {
      "type": "object",
      "required": ["id", "title", "original_description", "source"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]{2,5}-[0-9]+$" },
        "title": { "type": "string", "minLength": 3 },
        "original_description": { "type": "string", "minLength": 5 },
        "source": {
          "type": "object",
          "required": ["type", "uri", "content_sha256"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["linear", "github_issue", "user_report", "monitoring", "system_record"]
            },
            "uri": { "type": "string", "minLength": 3 },
            "reporter": { "type": "string", "minLength": 1 },
            "content_sha256": { "$ref": "#/definitions/sha256" }
          }
        }
      }
    },
    "expected_business_result": {
      "type": "object",
      "required": ["owner", "confirmed_at", "source_uri", "assertions_sha256", "assertions"],
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "confirmed_at": { "type": "string", "format": "date-time" },
        "source_uri": { "type": "string", "minLength": 3 },
        "assertions_sha256": { "$ref": "#/definitions/sha256" },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/assertion" }
        }
      }
    },
    "environment": {
      "type": "object",
      "required": ["target_system", "base_url_env", "expected_environment_id", "allowed_hosts_env"],
      "additionalProperties": false,
      "properties": {
        "target_system": { "$ref": "#/definitions/system" },
        "base_url_env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
        "expected_environment_id": { "type": "string", "minLength": 3 },
        "environment_id_header": { "type": "string", "default": "x-fesun-environment" },
        "allowed_hosts_env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
        "account": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "username_env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
            "password_env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
            "token_env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
            "role": { "type": "string" }
          }
        }
      }
    },
    "git": {
      "type": "object",
      "required": ["repo"],
      "additionalProperties": false,
      "properties": {
        "repo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "base_commit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
        "fixed_commit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" }
      }
    },
    "risk_claim": {
      "type": "object",
      "required": ["declared_level"],
      "additionalProperties": false,
      "properties": {
        "declared_level": { "$ref": "#/definitions/risk" }
      }
    },
    "business_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "affected_contracts": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "affected_spines": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "affected_segments": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
      }
    },
    "counterfactual": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string", "enum": ["CF-1", "CF-2", "CF-3", "SKIP"] },
        "reason_code": { "type": "string" },
        "expected_failure_signature": { "type": "string", "minLength": 3 },
        "replay": {
          "type": "object",
          "required": ["method", "path", "broken_payload", "expected_status", "response_selector", "expected_response", "test_title_pattern"],
          "additionalProperties": false,
          "properties": {
            "method": { "type": "string", "const": "POST" },
            "path": { "type": "string", "pattern": "^/" },
            "broken_payload": { "type": "object" },
            "expected_status": { "type": "integer", "minimum": 400, "maximum": 499 },
            "response_selector": { "type": "string", "pattern": "^/" },
            "expected_response": { "type": ["string", "number", "boolean", "null"] },
            "test_title_pattern": { "type": "string", "minLength": 3 }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "level": { "const": "CF-2" } }, "required": ["level"] },
          "then": { "required": ["expected_failure_signature", "replay"] }
        }
      ]
    },
    "test_data": {
      "type": "object",
      "required": ["namespace", "expires_after_hours", "cleanup_debt_limit"],
      "additionalProperties": false,
      "properties": {
        "namespace": { "type": "string", "pattern": "^e2e_[A-Za-z0-9_]+$" },
        "expires_after_hours": { "type": "integer", "minimum": 1, "maximum": 168 },
        "cleanup_debt_limit": { "type": "integer", "minimum": 0, "maximum": 10000 }
      }
    }
  },
  "definitions": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "system": {
      "type": "string",
      "enum": ["nupai-crm", "nupai-store", "nupai-mos", "fesun-platform"]
    },
    "risk": {
      "type": "string",
      "enum": ["FAST", "STANDARD", "CRITICAL", "CROSS_SYSTEM", "MANUAL_REVIEW"]
    },
    "assertion": {
      "type": "object",
      "required": [
        "id",
        "selector",
        "operator",
        "expected",
        "required_collectors",
        "min_independent_sources"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,80}$" },
        "selector": { "type": "string", "pattern": "^/" },
        "operator": {
          "type": "string",
          "enum": ["equals", "not_equals", "contains", "array_length_equals"]
        },
        "expected": { "type": ["string", "number", "boolean", "null"] },
        "required_collectors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["playwright_attachment", "trusted_http_probe", "contract_replay"]
          }
        },
        "min_independent_sources": { "type": "integer", "minimum": 1, "maximum": 3 },
        "probe": {
          "type": "object",
          "required": ["method", "path_template"],
          "additionalProperties": false,
          "properties": {
            "method": { "type": "string", "const": "GET" },
            "path_template": { "type": "string", "pattern": "^/" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "required_collectors": { "contains": { "const": "trusted_http_probe" } }
            }
          },
          "then": { "required": ["probe"] }
        }
      ]
    }
  }
}
