{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schema_version", "code_impact_map", "regression_rules"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "number", "const": 1.1 },
    "code_impact_map": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": false,
        "properties": {
          "contracts": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "segments": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "spines": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
        }
      }
    },
    "regression_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["match", "run"],
        "additionalProperties": false,
        "properties": {
          "match": { "type": "string" },
          "run": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}
