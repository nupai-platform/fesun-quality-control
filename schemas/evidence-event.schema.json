{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fesun.quality/schemas/evidence-event.schema.json",
  "title": "FESUN Evidence Event v1.1.1",
  "description": "机器封装的原始证据。核心 Oracle 必须由 trusted_http_probe 或 contract_replay 独立观察。",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "assertion_id",
    "evidence_type",
    "collector_kind",
    "system",
    "record_id",
    "captured_at",
    "raw_response",
    "raw_response_sha256",
    "provenance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "number", "const": 1.1 },
    "event_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "assertion_id": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,80}$" },
    "evidence_type": {
      "type": "string",
      "enum": ["backend_query", "network_response", "cross_system_query", "reload_state", "contract_replay"]
    },
    "collector_kind": {
      "type": "string",
      "enum": ["playwright_attachment", "trusted_http_probe", "contract_replay"]
    },
    "system": {
      "type": "string",
      "enum": ["nupai-crm", "nupai-store", "nupai-mos", "fesun-platform"]
    },
    "record_id": { "type": "string", "minLength": 3, "maxLength": 200 },
    "captured_at": { "type": "string", "format": "date-time" },
    "request": {
      "type": "object",
      "required": ["url", "method", "status"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "method": { "type": "string", "enum": ["GET", "POST", "PATCH", "PUT", "DELETE"] },
        "status": { "type": "integer", "minimum": 100, "maximum": 599 }
      }
    },
    "raw_response": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "raw_response_sha256": { "$ref": "#/definitions/sha256" },
    "redactions": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "provenance": {
      "type": "object",
      "required": [
        "run_id",
        "repo",
        "base_sha",
        "head_sha",
        "qc_sha",
        "packet_sha256",
        "test_sha256",
        "environment_id",
        "correlation_id"
      ],
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "base_sha": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
        "head_sha": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
        "qc_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "packet_sha256": { "$ref": "#/definitions/sha256" },
        "test_sha256": { "$ref": "#/definitions/sha256" },
        "environment_id": { "type": "string", "minLength": 3 },
        "correlation_id": { "type": "string", "minLength": 3, "maxLength": 200 }
      }
    }
  },
  "definitions": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
