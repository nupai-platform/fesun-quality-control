{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fesun.quality/schemas/execution-policy.schema.json",
  "title": "FESUN QC Execution Policy v1.1.1",
  "type": "object",
  "required": ["schema_version", "safety", "budget", "artifacts", "data_isolation", "state_machine"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "number", "const": 1.1 },
    "safety": {
      "type": "object",
      "required": ["max_retries", "retry_cannot_turn_fail_into_pass", "executing_ttl_minutes", "evidence_ttl_minutes", "final_verdict_timeout_minutes"],
      "additionalProperties": false,
      "properties": {
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 2 },
        "retry_cannot_turn_fail_into_pass": { "type": "boolean", "const": true },
        "executing_ttl_minutes": { "type": "integer", "minimum": 1, "maximum": 60 },
        "evidence_ttl_minutes": { "type": "integer", "minimum": 1, "maximum": 30 },
        "final_verdict_timeout_minutes": { "type": "integer", "minimum": 1, "maximum": 45 }
      }
    },
    "budget": {
      "type": "object",
      "required": ["max_cost_usd", "max_parallel_runs", "max_api_calls"],
      "additionalProperties": false,
      "properties": {
        "max_cost_usd": { "type": "number", "minimum": 0, "maximum": 2 },
        "max_parallel_runs": { "type": "integer", "minimum": 1, "maximum": 1 },
        "max_api_calls": { "type": "integer", "minimum": 1, "maximum": 500 }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["retention_days", "access", "redact_keys"],
      "additionalProperties": false,
      "properties": {
        "retention_days": { "type": "integer", "minimum": 1, "maximum": 14 },
        "access": { "type": "string", "const": "restricted" },
        "redact_keys": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } }
      }
    },
    "data_isolation": {
      "type": "object",
      "required": ["namespace_prefix", "default_expiry_hours", "cleanup_debt_hard_limit", "run2_requires_fresh_uuid"],
      "additionalProperties": false,
      "properties": {
        "namespace_prefix": { "type": "string", "const": "e2e_" },
        "default_expiry_hours": { "type": "integer", "minimum": 1, "maximum": 72 },
        "cleanup_debt_hard_limit": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "run2_requires_fresh_uuid": { "type": "boolean", "const": true }
      }
    },
    "state_machine": {
      "type": "object",
      "required": ["success_path", "terminal_states", "failure_classifications"],
      "additionalProperties": false,
      "properties": {
        "success_path": {
          "type": "array",
          "const": ["RECEIVED", "PRECHECKED", "RISK_CLASSIFIED", "IMPACT_ANALYZED", "TEST_IMPLEMENTED", "EXECUTING", "EVIDENCE_COLLECTED", "VERDICT_COMPUTED", "DONE"]
        },
        "terminal_states": {
          "type": "array",
          "const": ["DONE", "FAIL", "BLOCKED", "PARTIAL", "MANUAL_REVIEW"]
        },
        "failure_classifications": {
          "type": "array",
          "const": ["PRODUCT_FAILURE", "ENVIRONMENT", "INSUFFICIENT_EVIDENCE", "FLAKY"]
        }
      }
    }
  }
}
