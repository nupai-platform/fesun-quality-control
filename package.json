{
  "name": "fesun-quality-control",
  "version": "1.1.1",
  "private": true,
  "description": "FESUN 四系统可信开发验收内核 v1.1.1 — 中央治理仓库(证据不可伪造 / 风险分级 / 脊柱回归 / CI 硬门禁)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint scripts reporters tests",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "test:coverage": "c8 --check-coverage --lines 80 --functions 80 --branches 60 --reporter=text --reporter=json-summary npm test",
    "classify-risk": "tsx scripts/classify-risk.ts",
    "validate-packet": "tsx scripts/validate-packet.ts",
    "collect-oracle-evidence": "tsx scripts/collect-oracle-evidence.ts",
    "run-counterfactual": "tsx scripts/run-counterfactual.ts",
    "emit-alert": "tsx scripts/emit-alert.ts",
    "detect-weak-assertions": "tsx scripts/detect-weak-assertions.ts",
    "detect-business-code-change": "tsx scripts/detect-business-code-change.ts",
    "detect-orphan-integrations": "tsx scripts/detect-orphan-integrations.ts",
    "validate-spine-maps": "tsx scripts/validate-spine-maps.ts",
    "validate-workflows": "tsx scripts/validate-workflows.ts",
    "detect-governance-change": "tsx scripts/detect-governance-change.ts",
    "evidence-gate": "tsx scripts/evidence-gate.ts",
    "execution-gate": "tsx scripts/execution-gate.ts",
    "verdict-gate": "tsx scripts/verdict-gate.ts",
    "selftest": "tsx scripts/selftest.ts",
    "verify": "npm run lint && npm run typecheck && npm run validate-spine-maps && npm run validate-workflows && npm run test:coverage && npm run selftest && npm audit --audit-level=high"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.6.1",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/node": "^26.1.1",
    "c8": "^12.0.0",
    "eslint": "^10.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0"
  }
}
